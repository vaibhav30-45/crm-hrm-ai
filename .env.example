# -----------------------------
# FastAPI Configuration
# -----------------------------
FASTAPI_HOST=your-fastapi-host
FASTAPI_PORT=your-fastapi-port
FASTAPI_RELOAD=your-fastapi-reload-flag

# -----------------------------
# Authentication Configuration
# -----------------------------
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=your-jwt-algorithm
ACCESS_TOKEN_EXPIRE_MINUTES=your-token-expiry-minutes

# -----------------------------
# Database Configuration
# -----------------------------
MONGODB_URI=your-mongodb-uri
DB_NAME=your-database-name
SKIP_MONGODB=your-skip-mongodb-flag

# Mongo client tuning (optional)
MONGO_SERVER_SELECTION_TIMEOUT_MS=your-server-selection-timeout-ms
MONGO_CONNECT_TIMEOUT_MS=your-connect-timeout-ms
MONGO_SOCKET_TIMEOUT_MS=your-socket-timeout-ms
MONGODB_COLLECTION_NAME=your-mongodb-collection-name

# -----------------------------
# Frontend Configuration
# -----------------------------
CLIENT_URL=your-frontend-url

# -----------------------------
# Google Sheets Integration (optional)
# -----------------------------
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=your-google-service-account-key-file-path
GOOGLE_SHEETS_ID=your-google-sheets-id
GOOGLE_SHEETS_RANGE=your-google-sheets-range
GOOGLE_SPREADSHEET_NAME=your-google-spreadsheet-name
GOOGLE_WORKSHEET_NAME=your-google-worksheet-name

# -----------------------------
# Schema Configuration
# -----------------------------
CRM_SCHEMA_VERSION=your-crm-schema-version
REQUIRED_FIELDS=your-required-fields
UNIQUE_IDENTIFIER_FIELDS=your-unique-identifier-fields

# -----------------------------
# Pipeline Configuration
# -----------------------------
SYNC_INTERVAL_MINUTES=your-sync-interval-minutes
ML_BATCH_SIZE=your-ml-batch-size
ENABLE_AUTO_SYNC=your-enable-auto-sync-flag
ENABLE_ML_SCORING=your-enable-ml-scoring-flag
ENABLE_GOOGLE_SHEETS_SYNC=your-enable-google-sheets-sync-flag
ENABLE_AUTO_LEAD_PROCESSING=your-enable-auto-lead-processing-flag

# -----------------------------
# LLM / AI Provider Configuration
# -----------------------------
LLM_PROVIDER=your-llm-provider
LLM_API_KEY=your-llm-api-key
LLM_MODEL=your-llm-model

# Gemini
GEMINI_API_KEY=replace-with-gemini-api-key
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=your-gemini-model
GEMINI_TIMEOUT_SECONDS=your-gemini-timeout-seconds

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_LLM_MODEL=your-openai-llm-model
OPENAI_WHISPER_MODEL=your-openai-whisper-model

# Groq / Anthropic (optional)
GROQ_API_KEY=your-groq-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Conversation intelligence behavior (optional)
CONV_INTELLIGENCE_AUTO_FROM_AI_INSIGHTS=your-auto-chain-flag

# Lead prediction tuning (optional)
LEAD_CONFIDENCE_CALIBRATION_ENABLED=your-lead-calibration-enabled-flag
LEAD_RULE_ENGINE_ENABLED=your-lead-rule-engine-enabled-flag

# Search integration
SERP_API_KEY=replace-with-serpapi-key
